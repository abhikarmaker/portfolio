[{"/workspaces/portfolio/src/App.js":"1","/workspaces/portfolio/src/resumeData.js":"2","/workspaces/portfolio/src/components/header/Header.js":"3","/workspaces/portfolio/src/components/header/NavBar.js":"4","/workspaces/portfolio/src/components/about/About.js":"5","/workspaces/portfolio/src/components/resume/Resume.js":"6","/workspaces/portfolio/src/components/portfolio/Portfolio.js":"7","/workspaces/portfolio/src/components/contactus/ContactUs.js":"8","/workspaces/portfolio/src/components/footer/Footer.js":"9","/workspaces/portfolio/src/components/easytech/EasyTech.js":"10"},{"size":870,"mtime":1776317332324,"results":"11","hashOfConfig":"12"},{"size":10430,"mtime":1776317332332,"results":"13","hashOfConfig":"12"},{"size":1982,"mtime":1776317332329,"results":"14","hashOfConfig":"12"},{"size":1004,"mtime":1776317332330,"results":"15","hashOfConfig":"12"},{"size":1305,"mtime":1776317332324,"results":"16","hashOfConfig":"12"},{"size":8921,"mtime":1776317332332,"results":"17","hashOfConfig":"12"},{"size":2168,"mtime":1776317332330,"results":"18","hashOfConfig":"12"},{"size":3546,"mtime":1776317332324,"results":"19","hashOfConfig":"12"},{"size":2017,"mtime":1776317332329,"results":"20","hashOfConfig":"12"},{"size":3839,"mtime":1776317332326,"results":"21","hashOfConfig":"12"},{"filePath":"22","messages":"23","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"24","usedDeprecatedRules":"25"},"fzlcz4",{"filePath":"26","messages":"27","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"28","usedDeprecatedRules":"25"},{"filePath":"29","messages":"30","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"31","usedDeprecatedRules":"25"},{"filePath":"32","messages":"33","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"34","usedDeprecatedRules":"25"},{"filePath":"35","messages":"36","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"37","usedDeprecatedRules":"25"},{"filePath":"38","messages":"39","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"40","usedDeprecatedRules":"25"},{"filePath":"41","messages":"42","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"43","usedDeprecatedRules":"25"},{"filePath":"44","messages":"45","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"46","usedDeprecatedRules":"25"},{"filePath":"47","messages":"48","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"49","usedDeprecatedRules":"25"},{"filePath":"50","messages":"51","errorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"/workspaces/portfolio/src/App.js",["52"],"import './App.css';\nimport Header from './components/header/Header';\nimport NavBar from './components/header/NavBar';\nimport About from './components/about/About';\nimport Resume from './components/resume/Resume';\nimport Portfolio from './components/portfolio/Portfolio';\nimport EasyTech from './components/easytech/EasyTech';\nimport ContactUs from './components/contactus/ContactUs';\nimport Footer from './components/footer/Footer';\nimport resumeData from './resumeData';\n\nfunction App() {\n  return (\n    <div className=\"App\">\n      <Header resumeData={resumeData}/>\n      <NavBar />\n      <About resumeData={resumeData}/>\n      <Resume resumeData={resumeData}/>\n      <Portfolio resumeData={resumeData}/>\n      <EasyTech resumeData={resumeData}/>\n      <ContactUs resumeData={resumeData}/>\n      <Footer resumeData={resumeData}/>\n    </div>\n  );\n}\n\nexport default App;\n",[],"/workspaces/portfolio/src/resumeData.js",["53"],"let resumeData = {\n  imagebaseurl: \"https://abhikarmaker.github.io/portfolio/\",\n  name: \"Abhijeet Karmaker\",\n  role: \"Web Developer\",\n  linkedinId: \"abhijeet-karmaker\",\n  githubid: \"abhikarmaker\",\n  roleDescription:\n    \" I craft high-impact, modern web experiences with polished frontends and reliable full-stack architecture.\",\n  address1: \"\",\n  address2: \"\",\n  phoneNumber: \"+1 8194342389\",\n  website: \"https://easytechvancouver.ca\",\n  websiteLabel: \"Owner of easytechvancouver.ca\",\n  aboutme: [\n    {\n      name: \"My Experience\",\n      description:\n        \"I am a Senior QA Engineer with 7+ years of experience testing complex enterprise and infrastructure software. My background includes systems-level validation across distributed environments, virtualization stacks, networking, security controls, and cloud-integrated platforms.\",\n    },\n    {\n      name: \"My Skillset\",\n      description:\n        \"I specialize in virtualization testing (VMware ESXi, Hyper-V, KVM, Proxmox), network and security validation, endpoint management integrations (Azure AD, SAML, SSO), database testing (MySQL, MSSQL, PostgreSQL, Oracle), and cloud/SaaS ecosystems including Azure, Microsoft 365, and SASE. I build scalable test environments with Docker and Kubernetes, and I automate workflows using Python, PyTest, Bash, and CI/CD pipelines (Jenkins, GitLab CI, GitHub Actions).\",\n    },\n  ],\n  socialLinks: [\n    {\n      name: \"Linked In\",\n      id: \"abhijeet-karmaker\",\n      url: \"https://www.linkedin.com/in/abhijeet-karmaker/\",\n      className: \"fa fa-linkedin\",\n    },\n    {\n      name: \"GitHub\",\n      id: \"abhikarmaker\",\n      url: \"https://github.com/abhikarmaker\",\n      className: \"fa fa-github\",\n    },\n  ],\n  education: [\n    {\n      id: \"1\",\n      school: \"Dr. M. G. R. Educational and Research Institute University\",\n      degree: \"Bachelor of Technology\",\n      fieldofstudy: \"Computer Science Engineering\",\n      MonthOfPassing: \"May\",\n      YearOfPassing: \"2014\",\n      address: \"Chennai, Tamil Nadu, India\",\n      description:\n        \"Completed a three-month internship as a Junior Web Developer at Key Difference in Chennai, India in 2014.\",\n    },\n    {\n      id: \"2\",\n      school: \"Lambton College\",\n      degree: \"Post Graduation Certificate\",\n      fieldofstudy: \"Computer Software and Database Development\",\n      MonthOfPassing: \"May\",\n      YearOfPassing: \"2019\",\n      address: \"Sarnia, Ontario, Canada\",\n      description: \"Dean's Honour List, Winter 2018 and Fall 2017 semesters.\",\n    },\n  ],\n  work: [\n    {\n      id: \"1\",\n      CompanyName: \"Fortinet\",\n      Title: \"Intermediate Software Dev QA Specialist\",\n      address: \"Burnaby, British Columbia, Canada · Hybrid\",\n      StartingMonthAndYear: \"Feb 2025\",\n      MonthOfLeaving: \"Present\",\n      YearOfLeaving: \"\",\n      achievements: [\n        \"Led the development and maintenance of complex testing systems involving numerous network components, ensuring rigorous coverage across all major areas.\",\n        \"Collaborated closely with developers to design, develop, and implement manual and automated test cases, improving testing efficiency and accuracy.\",\n        \"Configured and managed complex manual testing environments for an Endpoint Management System across Windows Server, Windows clients, and Linux systems.\",\n        \"Carried out API testing with Postman and curl using HTTP methods to verify data and system behavior.\",\n        \"Reviewed regression results and internal tracking reports, proactively identifying, reproducing, and documenting software defects.\",\n      ],\n    },\n    {\n      id: \"2\",\n      CompanyName: \"Fortinet\",\n      Title: \"Software Dev QA Specialist\",\n      address: \"Vancouver, British Columbia, Canada\",\n      StartingMonthAndYear: \"Aug 2021\",\n      MonthOfLeaving: \"Feb\",\n      YearOfLeaving: \"2025\",\n      achievements: [\n        \"Used SQL extensively to validate data in database tables through DDL, DQL, and DML operations.\",\n        \"Performed CRUD-focused validation across tables, columns, and rows while ensuring data precision and consistency.\",\n        \"Built strong working knowledge of DBMS and RDBMS concepts, including structured and unstructured data handling.\",\n        \"Managed integration testing for Azure AD and Active Directory within the enterprise management application.\",\n        \"Developed and executed test plans covering both manual validation and automation with PyTest for API and GUI workflows.\",\n        \"Performed server-client and cloud application testing, including penetration testing activities and log analysis.\",\n      ],\n    },\n    {\n      id: \"3\",\n      CompanyName: \"Sherweb\",\n      Title: \"Microsoft 365 Technical Analyst Premier IV\",\n      address: \"Sherbrooke, Quebec, Canada\",\n      StartingMonthAndYear: \"March 2020\",\n      MonthOfLeaving: \"July 2021\",\n      YearOfLeaving: \"\",\n      achievements: [\n        \"Knowledge and experience in creating and running PowerShell scripts.\",\n        \"Specialized in advanced Microsoft 365 products such as Exchange, Azure, SharePoint, and Teams.\",\n        \"Assist Microsoft 365 Premier partners and customers by identifying causes and resolving technical issues through remote support and virtual machines.\",\n        \"Tackle new technical challenges daily, including security, Azure AD, Autopilot, and device management.\",\n      ],\n    },\n    {\n      id: \"6\",\n      CompanyName: \"Rance Computer Pvt. Ltd\",\n      Title: \"Software Testing Engineer\",\n      address: \"Kolkata, West Bengal, India\",\n      StartingMonthAndYear: \"Dec 2014\",\n      MonthOfLeaving: \"August\",\n      YearOfLeaving: \"2017\",\n      achievements: [\n        \"Worked on manual and automated testing of GUI and functional aspects of client-server and web-based applications across multiple stages of the SDLC and STLC.\",\n        \"Built a solid foundation in object-oriented programming concepts and Java.\",\n        \"Created test scripts using WebDriver, Selenium RC, Selenium IDE, and Selenium Grid in Java.\",\n        \"Performed functional, regression, and system testing with manual and automated tools including Selenium WebDriver.\",\n        \"Logged bugs in tracking systems such as JIRA and Mantis, then carried out regression testing after fixes.\",\n        \"Performed end-to-end, integration, and user acceptance testing.\",\n      ],\n    },\n  ],\n  certifications: [\n    {\n      id: \"1\",\n      name: \"Fortinet Network Security Expert Level 2: Certified Associate\",\n      issuingOrganization: \"Fortinet\",\n      issueDate: \"December 2022\",\n      credential: \"\",\n    },\n    {\n      id: \"2\",\n      name: \"Fortinet Network Security Expert Level 1: Certified Associate\",\n      issuingOrganization: \"Fortinet\",\n      issueDate: \"December 2021\",\n      credential: \"\",\n    },\n    {\n      id: \"3\",\n      name: \"Verified International Academic Qualifications\",\n      issuingOrganization: \"World Education Services\",\n      issueDate: \"April 2021\",\n      credential: \"Show credential\",\n    },\n    {\n      id: \"4\",\n      name: \"Oracle Database 11g: SQL Fundamentals I\",\n      issuingOrganization: \"Dr. MGR Educational & Research Institute University\",\n      issueDate: \"January 2014\",\n      credential: \"Credential ID 50104953\",\n    },\n    {\n      id: \"5\",\n      name: \"Microsoft 365 Certified: Fundamentals\",\n      issuingOrganization: \"Microsoft\",\n      issueDate: \"December 2020\",\n      credential: \"\",\n    },\n  ],\n  skillsDescription:\n    \"Frontend, backend, testing, and collaboration skills built through production support and web development work.\",\n  skills: [\n    {\n      id: \"1\",\n      skillname: \"JAVA\",\n      className: \"fa fa-code\",\n    },\n    {\n      id: \"2\",\n      skillname: \"HTML5\",\n      className: \"fa fa-html5\",\n    },\n    {\n      id: \"3\",\n      skillname: \"CSS\",\n      className: \"fa fa-css3\",\n    },\n    {\n      id: \"4\",\n      skillname: \"JavaScript\",\n      className: \"fa fa-code\",\n    },\n    {\n      id: \"5\",\n      skillname: \"Reactjs\",\n      className: \"fa fa-code-fork\",\n    },\n    {\n      id: \"6\",\n      skillname: \"SQL\",\n      className: \"fa fa-table\",\n    },\n    {\n      id: \"7\",\n      skillname: \"Python\",\n      className: \"fa fa-code\",\n    },\n    {\n      id: \"8\",\n      skillname: \"Kubernetes\",\n      className: \"fa fa-sitemap\",\n    },\n  ],\n  portfolio: [\n    {\n      id: \"1\",\n      name: \"Portfolio\",\n      description:\n        \"A personal portfolio built with React and local JSON-based content, designed and developed from scratch.\",\n      imgurl: \"images/portfolio/project2.jpg\",\n      link: \"https://abhikarmaker.github.io/portfolio/\",\n      githubLink: \"https://github.com/abhikarmaker/portfolio\",\n      fabIcon: \"fa fa-github\",\n    },\n    {\n      id: \"2\",\n      name: \"Weather App\",\n      description: \"A weather app built with React, REST APIs, and Bootstrap.\",\n      imgurl: \"images/portfolio/project3.jpg\",\n      link: \"https://weather-app-b731e.web.app/\",\n      githubLink: \"https://github.com/abhikarmaker/WeatherReactApp\",\n      fabIcon: \"fa fa-github\",\n    },\n    {\n      id: \"3\",\n      name: \"Netflix Clone\",\n      description:\n        \"A Netflix-inspired UI built with React, Hooks, React YouTube, and TMDB data.\",\n      imgurl: \"images/portfolio/Netflix-Clone.jpg\",\n      link: \"https://netflixstma-clone.web.app/\",\n      githubLink: \"https://github.com/abhikarmaker/netflixstma-clone\",\n      fabIcon: \"fa fa-github\",\n    },\n    {\n      id: \"4\",\n      name: \"Kitchen Depot\",\n      description:\n        \"A college project built with HTML5, CSS, JavaScript, jQuery, and JSON.\",\n      imgurl: \"images/portfolio/project1.jpg\",\n      link: \"https://abhikarmaker.github.io/THE-KITCHEN-DEPOT-FINAL/\",\n      githubLink: \"https://github.com/abhikarmaker/THE-KITCHEN-DEPOT-FINAL\",\n      fabIcon: \"fa fa-github\",\n    },\n  ],\n  easyTech: {\n    kicker: \"Owner spotlight\",\n    title: \"EasyTech Vancouver\",\n    description:\n      \"I also run EasyTech Vancouver, a local IT support and digital solutions service focused on approachable technical help for homes, small businesses, and the Metro Vancouver community.\",\n    highlights: [\n      \"Owner-led local IT consulting and troubleshooting\",\n      \"Friendly support for devices, connectivity, and digital setup\",\n      \"Clear communication with practical, client-focused solutions\",\n    ],\n    website: \"https://easytechvancouver.ca\",\n    phone: \"+1 8194342389\",\n    logoImage: \"images/easytech-logo.png\",\n    bannerImage: \"images/easytech-banner.png\",\n  },\n};\n\nexport default resumeData;\n","/workspaces/portfolio/src/components/header/Header.js",["54"],"import React, { Component } from \"react\";\n\nexport default class header extends Component {\n  render() {\n    const resumeData = this.props.resumeData || {};\n    const socialLinks = Array.isArray(resumeData.socialLinks) ? resumeData.socialLinks : [];\n    const name = resumeData.name || \"Abhijeet Karmaker\";\n    const role = resumeData.role || \"Web Developer\";\n    const roleDescription = resumeData.roleDescription || \"\";\n    const headerStyle = {\n      backgroundImage: `linear-gradient(180deg, rgba(10, 10, 10, 0.54), rgba(10, 10, 10, 0.74)), url(${process.env.PUBLIC_URL}/images/header-background.jpg)`,\n    };\n    return (\n      <React.Fragment>\n        <header id=\"home\" style={headerStyle}>\n          <div className=\"row banner\">\n            <div className=\"banner-text\">\n              <p className=\"hero-kicker\">Editorial portfolio</p>\n              <div className=\"typewriter\"><h1 className=\"responsive-headline\">I'm {name}.</h1></div>\n              <h3>\n                I am a {role}.{roleDescription}\n              </h3>\n              <hr />\n              <ul className=\"social\">\n                {socialLinks.map((item) => {\n                    return (\n                      <li key={item.name}>\n                        <a href={item.url} target=\"_blank\" rel=\"noreferrer noopener\" aria-label={item.name}>\n                          <i className={item.className} aria-hidden=\"true\"></i>\n                          <span className=\"sr-only\">{item.name}</span>\n                        </a>\n                      </li>\n                    );\n                  })}\n              </ul>\n            </div>\n          </div>\n\n          <p className=\"scrolldown\">\n            <a className=\"smoothscroll\" href=\"#about\" aria-label=\"Scroll to about section\">\n              <i className=\"icon-down-circle\" aria-hidden=\"true\"></i>\n              <span className=\"sr-only\">Scroll to about section</span>\n            </a>\n          </p>\n        </header>\n      </React.Fragment>\n    );\n  }\n}\n","/workspaces/portfolio/src/components/header/NavBar.js",["55"],"import React, { Component } from 'react';\n\nexport default class NavBar extends Component {\n    render() {\n        return (\n            <div>\n                <nav id=\"nav-wrap\" aria-label=\"Primary\">\n                    <a className=\"mobile-btn\" href=\"#nav-wrap\" title=\"Show navigation\">Show navigation</a>\n                    <a className=\"mobile-btn\" href=\"#home\" title=\"Hide navigation\">Hide navigation</a>\n                    <ul id=\"nav\" className=\"nav\">\n                        <li className=\"current\"><a className=\"smoothscroll\" href=\"#home\">Home</a></li>\n                        <li><a className=\"smoothscroll\" href=\"#about\">About</a></li>\n                        <li><a className=\"smoothscroll\" href=\"#resume\">Resume</a></li>\n                        <li><a className=\"smoothscroll\" href=\"#portfolio\">Portfolio</a></li>\n                        <li><a className=\"smoothscroll\" href=\"#contactus\">Contact</a></li>\n                    </ul> \n                </nav>\n            </div>\n        )\n    }\n}\n","/workspaces/portfolio/src/components/about/About.js",["56"],"import React, { Component } from \"react\";\n\nexport default class About extends Component {\n  render() {\n    const resumeData = this.props.resumeData || {};\n    const aboutItems = Array.isArray(resumeData.aboutme) ? resumeData.aboutme : [];\n    const name = resumeData.name || \"Abhijeet Karmaker\";\n    return (\n      <section id=\"about\">\n        <div className=\"row\">\n          <h1>About Me</h1>\n          <div className=\"three columns\">\n            <img\n              className=\"profile-pic\"\n              src={`${process.env.PUBLIC_URL}/images/mypic1.jpg`}\n              alt={`${name} portrait`}\n              loading=\"lazy\"\n              decoding=\"async\"\n            />\n          </div>\n          <div className=\"nine columns main-col\">\n            {aboutItems.map((item, index) => {\n                return (\n                  <React.Fragment key={`${item.name}-${index}`}>\n                    <h2>{item.name}</h2>\n                    <p>{item.description}</p>\n                  </React.Fragment>\n                );\n              })}\n            <div className=\"download\">\n              <a href={`${process.env.PUBLIC_URL}/files/Resume.pdf`} target=\"_blank\" rel=\"noreferrer noopener\" className=\"button\">Download Resume</a>\n            </div>\n          </div>\n        </div>\n      </section>\n    );\n  }\n}\n","/workspaces/portfolio/src/components/resume/Resume.js",["57"],"import React, { Component } from \"react\";\n\nconst KEYWORD_PATTERNS = [\n  { label: \"Automation\", pattern: /\\bautomat(e|ed|ion|ing)\\b/i },\n  { label: \"Manual Testing\", pattern: /\\bmanual\\b/i },\n  { label: \"API Testing\", pattern: /\\bapi\\b/i },\n  { label: \"Postman\", pattern: /\\bpostman\\b/i },\n  { label: \"SQL\", pattern: /\\bsql\\b/i },\n  { label: \"PyTest\", pattern: /\\bpytest\\b/i },\n  { label: \"Azure AD\", pattern: /\\bazure ad\\b/i },\n  { label: \"Active Directory\", pattern: /\\bactive directory\\b/i },\n  { label: \"Windows\", pattern: /\\bwindows\\b/i },\n  { label: \"Linux\", pattern: /\\blinux\\b/i },\n  { label: \"Cloud\", pattern: /\\bcloud\\b/i },\n  { label: \"Regression\", pattern: /\\bregression\\b/i },\n  { label: \"Defect Tracking\", pattern: /\\bdefect|bug|jira|mantis\\b/i },\n  { label: \"Integration Testing\", pattern: /\\bintegration\\b/i },\n  { label: \"Security Testing\", pattern: /\\bsecurity|penetration\\b/i },\n  { label: \"Troubleshooting\", pattern: /\\btroubleshoot|resolv(e|ing)\\b/i },\n  { label: \"Collaboration\", pattern: /\\bcollaborat(e|ed|ion)\\b/i },\n  { label: \"Test Design\", pattern: /\\btest cases?|test plans?\\b/i },\n];\n\nfunction extractKeywords(text) {\n  if (typeof text !== \"string\") {\n    return [];\n  }\n  const matches = KEYWORD_PATTERNS.filter((item) => item.pattern.test(text)).map(\n    (item) => item.label\n  );\n  return matches.slice(0, 4);\n}\n\nexport default class resume extends Component {\n\n  render() {\n    const resumeData = this.props.resumeData || {};\n    const education = Array.isArray(resumeData.education) ? resumeData.education : [];\n    const work = Array.isArray(resumeData.work) ? resumeData.work : [];\n    const certifications = Array.isArray(resumeData.certifications) ? resumeData.certifications : [];\n    const skills = Array.isArray(resumeData.skills) ? resumeData.skills : [];\n\n    return (\n      <div>\n        <section id=\"resume\">\n          <div className=\"row education\">\n            <div className=\"three columns header-col\">\n              <h1>\n                <span>Education</span>\n              </h1>\n            </div>\n            <div className=\"nine columns main-col\">\n              {education.map((item) => {\n                  return (\n                    <React.Fragment key={item.id}>\n                      <div className=\"row item\">\n                        <div className=\"twelve columns\">\n                          <h3>{item.school}</h3>\n                          <p className=\"info\">\n                            {item.degree} <span>&bull;</span>{\" \"}\n                            {item.fieldofstudy}\n                            <span>&bull;</span>{\" \"}\n                            <em className=\"date\">\n                              {item.MonthOfPassing} {item.YearOfPassing}\n                            </em>\n                            <span>&bull;</span> {item.address}\n                          </p>\n                          <p>Achievements : {item.description}</p>\n                        </div>\n                      </div>\n                    </React.Fragment>\n                  );\n                })}\n            </div>\n          </div>\n          <div className=\"row work\">\n            <div className=\"three columns header-col\">\n              <h1>\n                <span>Experience</span>\n              </h1>\n            </div>\n\n            <div className=\"nine columns main-col\">\n              {work.map((item) => {\n                  const achievements = Array.isArray(item.achievements)\n                    ? item.achievements\n                    : Object.values(item.Achievements || {}).filter(Boolean);\n                  const endDate = item.YearOfLeaving\n                    ? `${item.MonthOfLeaving} ${item.YearOfLeaving}`\n                    : item.MonthOfLeaving;\n\n                  return (\n                    <React.Fragment key={item.id}>\n                      <div className=\"row item\">\n                        <div className=\"twelve columns\">\n                          <h3>{item.Title}</h3>\n                          <p className=\"info\">\n                            {item.CompanyName}\n                            <span>&bull;</span>{\" \"}\n                            <em className=\"date\">\n                              {item.StartingMonthAndYear} - {endDate}\n                            </em>\n                            <span>&bull;</span>{\" \"}{item.address}\n                          </p>\n                          <hr></hr>\n                          <h1>\n                            Roles & Responsibilities\n                          </h1>\n                            <ul className=\"roles\">\n                              {achievements.map((achievement, index) => {\n                                const keywords = extractKeywords(achievement);\n\n                                return (\n                                  <li key={`${item.id}-${index}`} className=\"role-item\">\n                                    <p className=\"role-text\">{achievement}</p>\n                                    {keywords.length ? (\n                                      <div className=\"role-keywords\" aria-label=\"Key skills\">\n                                        {keywords.map((keyword) => (\n                                          <span\n                                            key={`${achievement}-${keyword}`}\n                                            className=\"role-chip\"\n                                          >\n                                            {keyword}\n                                          </span>\n                                        ))}\n                                      </div>\n                                    ) : null}\n                                  </li>\n                                );\n                              })}\n                            </ul>                          \n                        </div>\n                      </div>\n                    </React.Fragment>\n                  );\n                })}\n            </div>\n          </div>\n\n          <div className=\"row work\">\n            <div className=\"three columns header-col\">\n              <h1>\n                <span>Certifications</span>\n              </h1>\n            </div>\n\n            <div className=\"nine columns main-col\">\n              {certifications.map((item) => {\n                  const hasCredentialLink =\n                    typeof item.credential === \"string\" &&\n                    /^https?:\\/\\//.test(item.credential);\n\n                  return (\n                    <React.Fragment key={item.id}>\n                      <div className=\"row item\">\n                        <div className=\"twelve columns\">\n                          <h3>{item.name}</h3>\n                          <p className=\"info\">\n                            {item.issuingOrganization}\n                            <span>&bull;</span>{\" \"}\n                            <em className=\"date\">{item.issueDate}</em>\n                          </p>\n                          {item.credential ? (\n                            <p className=\"info\">\n                              {hasCredentialLink ? (\n                                <a\n                                  href={item.credential}\n                                  target=\"_blank\"\n                                  rel=\"noreferrer noopener\"\n                                >\n                                  Credential\n                                </a>\n                              ) : (\n                                item.credential\n                              )}\n                            </p>\n                          ) : null}\n                        </div>\n                      </div>\n                    </React.Fragment>\n                  );\n                })}\n            </div>\n          </div>\n\n          <div className=\"row skill\">\n            <div className=\"three columns header-col\">\n              <h1>\n                <span>Skills</span>\n              </h1>\n            </div>\n            <div className=\"nine columns main-col\">\n              {/* <p>{resumeData.skillsDescription}</p> */}\n              <div className=\"bars\">\n                <ul className=\"skills\">\n                  {skills.map((item) => {\n                      return (\n                        <React.Fragment key={item.id}>\n                          <li className=\"skill-card\">\n                            <div className=\"skill-meta\">\n                              <em>{item.skillname}</em>\n                              <i className={item.className} aria-hidden=\"true\"></i>\n                            </div>\n                            <span\n                              className={`bar-expand ${item.skillname.toLowerCase()}`}\n                            ></span>\n                          </li>\n                        </React.Fragment>\n                      );\n                    })}\n                </ul>\n              </div>\n            </div>\n          </div>\n        </section>\n      </div>\n    );\n  }\n}\n","/workspaces/portfolio/src/components/portfolio/Portfolio.js",["58"],"import React, { Component } from \"react\";\n\nexport default class portfolio extends Component {\n  render() {\n    const resumeData = this.props.resumeData || {};\n    const projects = Array.isArray(resumeData.portfolio) ? resumeData.portfolio : [];\n    return (\n      <section id=\"portfolio\">\n        <div className=\"row\">\n          <div className=\"twelve columns collapsed\">\n            <h1>Check Out Some of My Works</h1>\n            <div id=\"portfolio-wrapper\">\n              {/* className=\"bgrid-quarters s-bgrid-thirds cf\" */}\n              {projects.map((item) => {\n                  return (\n                    <React.Fragment key={item.id}>\n                      <div className=\"columns portfolio-item\">\n                        <a href={item.link} target=\"_blank\" rel=\"noreferrer noopener\" className=\"portfolio-link\">\n                          <img\n                            src={`${process.env.PUBLIC_URL}/${item.imgurl}`}\n                            className=\"item-img\"\n                            alt={`${item.name} preview`}\n                            loading=\"lazy\"\n                            decoding=\"async\"\n                          />\n                        </a>\n                        <div className=\"portfolio-copy\">\n                          <h5>{item.name}</h5>\n                          <p>{item.description}</p>\n                          {item.githubLink ? (\n                            <a\n                              href={item.githubLink}\n                              target=\"_blank\"\n                              rel=\"noreferrer noopener\"\n                              aria-label={`${item.name} source code`}\n                              className=\"portfolio-github\"\n                            >\n                              <i className={item.fabIcon} />\n                              <span className=\"sr-only\">{item.name} source code</span>\n                            </a>\n                          ) : null}\n                        </div>\n                      </div>\n                    </React.Fragment>\n                  );\n                })}\n            </div>\n          </div>\n        </div>\n      </section>\n    );\n  }\n}\n","/workspaces/portfolio/src/components/contactus/ContactUs.js",["59"],"import React, { Component } from \"react\";\n\nexport default class contactus extends Component {\n  render() {\n    const resumeData = this.props.resumeData || {};\n    const socialLinks = Array.isArray(resumeData.socialLinks) ? resumeData.socialLinks : [];\n    const phoneNumber = typeof resumeData.phoneNumber === \"string\" ? resumeData.phoneNumber : \"\";\n    const phoneHref = `tel:${phoneNumber.replace(/[^+\\d]/g, '')}`;\n    const easyTechLogoSrc = `${process.env.PUBLIC_URL}/images/easytech-logo.png`;\n\n    return (\n      <section id=\"contactus\">\n        <h2>Contact</h2>\n        <div className=\"contact-shell section-head\">\n          <div className=\"contact-intro\">\n            <p className=\"lead\">\n              Feel free to reach out about opportunities, collaborations, or project ideas.\n            </p>\n          </div>\n        </div>\n        <div className=\"contact-shell contact-grid\">\n          <aside className=\"contact-card footer-widgets\">\n            <h3>Social Profiles</h3>\n            <ul className=\"social-links\">\n              {socialLinks.map((item) => {\n                  return (\n                    <li key={item.className}>\n                      <h4>\n                        <span>{item.name}</span>{\" \"}\n                        <i className={item.className} aria-hidden=\"true\" />{\" \"}\n                        <a href={item.url} target=\"_blank\" rel=\"noreferrer noopener\">\n                          {item.id}\n                        </a>\n                      </h4>\n                    </li>\n                  );\n                })}\n            </ul>\n            <h3>Details</h3>\n            <address className=\"address\">\n              <span><i className=\"fa fa-user\" aria-hidden=\"true\" /> {resumeData.name}</span>\n              <br />\n              <a href={phoneHref}><i className=\"fa fa-phone\" aria-hidden=\"true\" /> {phoneNumber}</a>\n            </address>\n          </aside>\n          <div className=\"contact-card footer-widget\" aria-label=\"LinkedIn profile badge\">\n            <h3>Professional Profiles</h3>\n            <div\n              className=\"LI-profile-badge\"\n              data-version=\"v1\"\n              data-size=\"large\"\n              data-locale=\"en_US\"\n              data-type=\"vertical\"\n              data-theme=\"light\"\n              data-vanity=\"abhijeet-karmaker\"\n            >\n              <a\n                className=\"LI-simple-link contact-profile-link\"\n                href=\"https://ca.linkedin.com/in/abhijeet-karmaker?trk=profile-badge\"\n              >\n                <i className=\"fa fa-linkedin\" aria-hidden=\"true\" />\n                <span className=\"contact-profile-label\">Abhijeet Karmaker on LinkedIn</span>\n              </a>\n            </div>\n            <a\n              href={resumeData.website}\n              target=\"_blank\"\n              rel=\"noreferrer noopener\"\n              className=\"contact-easytech-link contact-profile-link\"\n              aria-label={resumeData.websiteLabel || \"Owner of easytechvancouver.ca\"}\n            >\n              <span className=\"contact-easytech-mark\" aria-hidden=\"true\">\n                <img\n                  src={easyTechLogoSrc}\n                  alt=\"\"\n                  className=\"contact-easytech-logo\"\n                />\n              </span>\n              <span className=\"contact-easytech-label contact-profile-label\">\n                <strong>EasyTech Vancouver</strong>\n                <span className=\"contact-profile-meta\">Owner</span>\n              </span>\n            </a>\n          </div>\n        </div>\n      </section>\n    );\n  }\n}\n","/workspaces/portfolio/src/components/footer/Footer.js",["60"],"import React, { Component } from 'react'\n\nexport default class footer extends Component {\n  render() {\n    const resumeData = this.props.resumeData || {};\n    const socialLinks = Array.isArray(resumeData.socialLinks) ? resumeData.socialLinks : [];\n    const currentYear = new Date().getFullYear();\n\n    return (\n      <div>\n        <footer>\n          <div className=\"row\">\n            <div className=\"twelve columns\">\n              <ul className=\"social-links\">\n                {\n                  socialLinks.map((item) => {\n                    return (\n                      <React.Fragment key={item.url}>\n                      <li>\n                        <a href={item.url} target=\"_blank\" rel=\"noreferrer noopener\" aria-label={item.name}>\n                          {item.iconImage ? (\n                            <img\n                              src={`${process.env.PUBLIC_URL}/${item.iconImage}`}\n                              alt=\"\"\n                              className=\"footer-social-logo\"\n                              aria-hidden=\"true\"\n                            />\n                          ) : (\n                            <i className={item.className} aria-hidden=\"true\" />\n                          )}\n                          <span className=\"sr-only\">{item.name}</span>\n                        </a>\n                      </li>\n                      </React.Fragment>\n                    )\n                  })\n                }\n              </ul>\n              <ul className=\"copyright\">\n                <li>© {currentYear} Abhijeet Karmaker</li>\n                <li>Design by <a title=\"AbhijeetKarmaker\" href=\"https://github.com/abhikarmaker\">Abhijeet Karmaker</a></li>\n              </ul>\n            </div>\n            <div id=\"go-top\"><a className=\"smoothscroll\" title=\"Back to Top\" href=\"#home\" aria-label=\"Back to top\"><i className=\"icon-up-open\" aria-hidden=\"true\" /><span className=\"sr-only\">Back to top</span></a></div>\n          </div>\n        </footer>\n      </div>\n    )\n  }\n}\n","/workspaces/portfolio/src/components/easytech/EasyTech.js",["61"],{"ruleId":null,"fatal":true,"severity":2,"message":"62"},{"ruleId":null,"fatal":true,"severity":2,"message":"63"},{"ruleId":null,"fatal":true,"severity":2,"message":"64"},{"ruleId":null,"fatal":true,"severity":2,"message":"65"},{"ruleId":null,"fatal":true,"severity":2,"message":"66"},{"ruleId":null,"fatal":true,"severity":2,"message":"67"},{"ruleId":null,"fatal":true,"severity":2,"message":"68"},{"ruleId":null,"fatal":true,"severity":2,"message":"69"},{"ruleId":null,"fatal":true,"severity":2,"message":"70"},{"ruleId":null,"fatal":true,"severity":2,"message":"71"},"Parsing error: [BABEL] /workspaces/portfolio/src/App.js: Cannot find module '/workspaces/portfolio/node_modules/babel-preset-rea